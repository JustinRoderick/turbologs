{
  "name": "turbologs",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "dev": "npx convex dev --once && concurrently -r npm:dev:web npm:dev:convex",
    "dev:web": "vite dev",
    "dev:ts": "tsc -b -w",
    "dev:convex": "npx convex dev",
    "build": "vite build && tsc --noEmit",
    "start": "node .output/server/index.mjs",
    "lint:eslint": "tsc && eslint .  --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "lint:type-aware": "oxlint --type-aware",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "env:validate": "better-env validate --environment development"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@convex-dev/better-auth": "^0.10.13",
    "@convex-dev/rate-limiter": "^0.3.2",
    "@convex-dev/react-query": "^0.1.0",
    "@convex-dev/stripe": "^0.1.3",
    "@fontsource-variable/geist-mono": "^5.2.7",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@tanstack/react-form-start": "^1.28.4",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-router": "^1.166.2",
    "@tanstack/react-router-ssr-query": "^1.166.2",
    "@tanstack/react-router-with-query": "^1.130.17",
    "@tanstack/react-start": "^1.166.2",
    "@tanstack/react-table": "^8.21.3",
    "better-auth": "1.4.9",
    "better-env": "^0.3.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "convex": "^1.32.0",
    "date-fns": "^4.1.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.577.0",
    "motion": "^12.35.0",
    "next-themes": "^0.4.6",
    "nuqs": "^2.8.9",
    "posthog-js": "^1.360.1",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.4",
    "react-resizable-panels": "^4.7.2",
    "recharts": "2.15.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "vaul": "^1.1.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@convex-dev/eslint-plugin": "^1.1.1",
    "@netlify/vite-plugin-tanstack-start": "^1.2.20",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/eslint-config": "^0.3.4",
    "@tanstack/react-devtools": "^0.9.9",
    "@tanstack/react-form-devtools": "^0.2.17",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "concurrently": "~9.2.1",
    "oxfmt": "^0.35.0",
    "oxlint": "^1.51.0",
    "oxlint-tsgolint": "^0.14.2",
    "prettier": "^3.8.1",
    "shadcn": "^4.0.3",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
